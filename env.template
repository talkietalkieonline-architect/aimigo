# ═══════════════════════════════════════════════
#  AIMIGO — Production Environment Variables
#  Скопируйте в .env и заполните значения:
#    cp env.template .env
# ═══════════════════════════════════════════════

# ── Домен ──
DOMAIN=aimigo.ru

# ── PostgreSQL ──
POSTGRES_USER=aimigo
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
POSTGRES_DB=aimigo

# ── Redis ──
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ── JWT Secret (генерируйте: openssl rand -hex 32) ──
SECRET_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL

# ── LLM Провайдеры (минимум один ключ нужен) ──

# Gemini (БЕСПЛАТНО 15 req/min) — рекомендуется для старта
# Получить: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# OpenAI (платный)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Groq (БЕСПЛАТНО, Llama 3.3 70B)
# Получить: https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Провайдер по умолчанию для Дворецкого: gemini / openai / groq
DEFAULT_LLM_PROVIDER=gemini

# ── Админ ──
ADMIN_PHONES=["+79214787478"]
